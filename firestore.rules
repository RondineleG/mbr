rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   MrBur "A Ordem" — Firestore Security Rules
   Modelo: campo role:"admin" em users/{uid} (sem Cloud Functions).
   Limitação assumida (MVP): pontos são ajustados no cliente — em
   produção endurecida, mover adjustPoints para Cloud Functions.
   ═══════════════════════════════════════════════════════════════ */
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Agentes: leitura por autenticados (ranking); escrita do próprio doc.
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if owner(uid) && request.resource.data.role == 'agent';
      allow update: if isAdmin()
        || (owner(uid)
            && request.resource.data.role == 'agent'
            && request.resource.data.codename == resource.data.codename);
      allow delete: if isAdmin();
    }

    // Catálogo e recompensas: leitura pública, escrita só admin.
    match /products/{id}  { allow read: if true; allow write: if isAdmin(); }
    match /rewards/{id}   { allow read: if true; allow write: if isAdmin(); }

    // Pedidos: agente cria os seus (status inicial 'received');
    // troca de status é exclusiva do admin.
    match /orders/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'received';
      allow update, delete: if isAdmin();
    }

    // Resgates: agente cria os seus; admin gerencia.
    match /redemptions/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Extrato de méritos: imutável após criação.
    match /pointsHistory/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // Convites: leitura pública (validar antes do cadastro);
    // consumo marca used=true uma única vez; criação/lista só admin.
    match /invites/{code} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if signedIn()
        && resource.data.used == false
        && request.resource.data.used == true;
    }
  }
}
