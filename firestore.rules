rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   MrBur "A Ordem" — Firestore Security Rules
   MVP: Regras mais permissivas para funcionamento correto
   ═══════════════════════════════════════════════════════════════ */
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Usuários: leitura por autenticados, escrita do próprio doc ou admin
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin() || owner(uid);
      allow delete: if isAdmin();
    }

    // Catálogo e recompensas: leitura pública, escrita por autenticados
    match /products/{id}  { allow read: if true; allow write: if signedIn(); }
    match /rewards/{id}   { allow read: if true; allow write: if signedIn(); }
    match /missions/{id}  { allow read: if true; allow write: if signedIn(); }

    // Pedidos: usuários autenticados podem criar e ler seus próprios
    match /orders/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Resgates: usuários autenticados podem criar e ler seus próprios
    match /redemptions/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Histórico de pontos: usuários autenticados podem criar e ler
    match /pointsHistory/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if false;
      allow delete: if false;
    }

    // Histórico de Metiqos: usuários autenticados podem criar e ler
    match /metiqosHistory/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if false;
      allow delete: if false;
    }

    // Convites: leitura pública para validação, escrita por autenticados
    match /invites/{code} {
      allow get: if true;
      allow list: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    // Progresso de missões: usuário lê/escreve seu próprio progresso
    match /missionProgress/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
