rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   MrBur "A Ordem" — Firestore Security Rules
   MVP: Regras mais permissivas para funcionamento correto
   ═══════════════════════════════════════════════════════════════ */
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Usuários: leitura por autenticados, escrita do próprio doc ou admin
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin() || owner(uid);
      allow delete: if isAdmin();
    }

    // Lookup codinome→e-mail (login por codinome). Resolvível por ID exato (get),
    // mas NÃO enumerável (list negado) — não dá pra varrer todos os e-mails.
    // Cada um só grava o mapa que aponta para o PRÓPRIO e-mail.
    match /codenames/{slug} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isAdmin()
        || (signedIn() && request.resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }

    // Config do app (ex.: versão oficial p/ forçar atualização): leitura pública, escrita admin.
    match /config/{doc} { allow read: if true; allow write: if isAdmin(); }

    // Catálogo e recompensas: leitura pública, escrita por autenticados
    match /products/{id}  { allow read: if true; allow write: if signedIn(); }
    match /rewards/{id}   { allow read: if true; allow write: if signedIn(); }
    match /missions/{id}  { allow read: if true; allow write: if signedIn(); }
    // Lanches gerados (criações): leitura pública; criar/atualizar por autenticados
    // (dono no 1º pedido, forks/stars depois). Exclusão só admin.
    match /lanches/{id} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }
    // Comentários dos lanches (estilo GitHub): leitura pública, criação autenticada.
    match /lancheComentarios/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }
    // Eventos de fork (ranking semanal): leitura pública, criação autenticada.
    match /forkEvents/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // Pedidos: dono, admin ou o motoboy/agente responsável pela entrega podem atualizar.
    match /orders/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (signedIn() && resource.data.agenteResponsavel == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Resgates: usuários autenticados podem criar e ler seus próprios
    match /redemptions/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Histórico de pontos: usuários autenticados podem criar e ler
    match /pointsHistory/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if false;
      allow delete: if false;
    }

    // Transações de pontos: usuários autenticados podem criar e ler
    match /pointTransactions/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if false;
      allow delete: if false;
    }

    // Convites: leitura pública por código (validação no cadastro). Apenas o
    // admin cria convites; o update (consumir/marcar usado) fica liberado para
    // autenticados pois o cadastro consome o convite antes do papel existir.
    match /invites/{code} {
      allow get: if true;
      allow list: if signedIn();
      allow create: if isAdmin();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    // Progresso de missões: usuário lê/escreve seu próprio progresso
    match /missionProgress/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Chat de pedidos (motoboy ↔ cliente): autenticados leem e criam; imutável.
    match /orderMessages/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
