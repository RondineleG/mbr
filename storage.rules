rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   MrBur "A Ordem" — Storage Security Rules
   Imagens de produto: leitura pública, escrita por autenticados.
   NOTA: Storage Rules não leem Firestore facilmente; para restringir
   a escrita só a admins em produção, use Custom Claims (role=admin)
   e troque por: allow write: if request.auth.token.admin == true;
   ═══════════════════════════════════════════════════════════════ */
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024          // máx 5MB
        && request.resource.contentType.matches('image/.*'); // só imagens
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
